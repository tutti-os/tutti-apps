{
  "schemaVersion": "tutti-apps.publish.v1",
  "buildRoot": "build/tutti-app",
  "apps": {
    "daily-tech-radar": {
      "packageName": "@tutti-apps/daily-tech-radar",
      "sourceDir": "apps/daily-tech-radar",
      "packageSourceDir": "apps/daily-tech-radar/tutti-package",
      "packageDir": "build/tutti-app/daily-tech-radar/package",
      "iconPath": "build/tutti-app/daily-tech-radar/package/icon.png",
      "packageCommand": "pnpm package:tutti --app daily-tech-radar"
    },
    "tutti-onboarding": {
      "packageName": "@tutti-apps/tutti-onboarding",
      "packageKind": "static",
      "runtimeProfile": "standalone",
      "standaloneTargets": ["darwin-arm64", "darwin-amd64"],
      "sourceDir": "apps/tutti-onboarding",
      "packageSourceDir": "apps/tutti-onboarding/tutti-package",
      "packageDir": "build/tutti-app/tutti-onboarding/package",
      "iconPath": "build/tutti-app/tutti-onboarding/package/icon.webp",
      "packageCommand": "pnpm package:tutti --app tutti-onboarding"
    }
  },
  "environments": {
    "production": {
      "defaultAppId": "daily-tech-radar",
      "appIds": ["daily-tech-radar", "tutti-onboarding"]
    },
    "staging": {
      "defaultAppId": "daily-tech-radar",
      "appIds": ["daily-tech-radar", "tutti-onboarding"]
    }
  }
}
