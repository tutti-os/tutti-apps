{
  "schemaVersion": "tutti.app.manifest.v1",
  "appId": "daily-tech-radar",
  "version": "0.0.10",
  "name": "Daily Product Radar",
  "description": "Summarizes daily new products and popular open-source projects.",
  "icon": {
    "type": "asset",
    "src": "icon.png"
  },
  "runtime": {
    "bootstrap": "bootstrap.sh",
    "healthcheckPath": "/api/health"
  },
  "cli": {
    "manifest": "tutti.cli.json"
  },
  "localizationInfo": {
    "defaultLocale": "en-US",
    "additionalLocales": [
      {
        "locale": "zh-CN",
        "file": "locales/zh-CN/manifest.json"
      }
    ]
  },
  "launch": {
    "mode": "workspace-open"
  },
  "author": {
    "name": "Tutti"
  },
  "tags": ["daily-tech-radar", "producthunt", "github", "trends"]
}
