{
  "schemaVersion": "tutti.app.cli.v1",
  "scope": "onboarding",
  "description": "Inspect the Getting Started onboarding app status.",
  "documentation": {
    "file": "COMMANDS.md"
  },
  "commands": [
    {
      "path": ["status"],
      "summary": "Show onboarding status",
      "description": "Return the packaged onboarding app status.",
      "output": {
        "defaultMode": "json",
        "json": true
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/status",
        "timeoutMs": 10000
      }
    }
  ]
}
