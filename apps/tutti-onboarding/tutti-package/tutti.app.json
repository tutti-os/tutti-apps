{
  "schemaVersion": "tutti.app.manifest.v1",
  "appId": "tutti-onboarding",
  "version": "0.1.0",
  "name": "Getting Started",
  "description": "Learn Tutti and Agent collaboration",
  "icon": {
    "type": "asset",
    "src": "icon.webp"
  },
  "runtime": {
    "bootstrap": "bootstrap.sh",
    "healthcheckPath": "/healthz",
    "profile": "node-static"
  },
  "cli": {
    "manifest": "tutti.cli.json"
  },
  "window": {
    "minWidth": 520,
    "minHeight": 640
  },
  "localizationInfo": {
    "defaultLocale": "en",
    "additionalLocales": [
      {
        "locale": "zh-CN",
        "file": "locales/zh-CN/manifest.json"
      }
    ]
  },
  "launch": {
    "mode": "workspace-open"
  },
  "author": {
    "name": "Tutti"
  },
  "tags": ["onboarding", "getting-started", "workspace"]
}
