{
  "name": "nextop-apps",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "biome format --write .",
    "i18n:check": "pnpm --filter @nextop-apps/daily-tech-radar i18n:check",
    "lint": "biome check .",
    "package:tutti": "node scripts/package-tutti-app.mjs",
    "test:workspace": "node --test tests/*.test.mjs",
    "test:packages": "turbo run test",
    "test": "pnpm run test:workspace && pnpm run test:packages",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
